# ==============================
# Backend - Producción
# Copia este archivo a .env.production
# ==============================

# API
NODE_ENV=production
HOST=127.0.0.1
PORT=3000

# Reintentos DB al iniciar
DB_RETRY_ATTEMPTS=10
DB_RETRY_DELAY_MS=3000

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=usuario_mysql
DB_PASSWORD=CAMBIAR_PASSWORD_DB
DB_NAME=poa_pac

# Seguridad
JWT_SECRET=CAMBIAR_POR_VALOR_LARGO_Y_SEGURO
DEFAULT_ADMIN_USER=admin
DEFAULT_ADMIN_PASSWORD=CAMBIAR_PASSWORD_ADMIN

# Reglas funcionales
ALLOW_MANUAL_COMPLETION_DATE=true

# Notificaciones
NOTIFICATIONS_ENABLED=false
ALERT_DAYS_BEFORE=3
EMAIL_FROM=Sistema Seguimiento <noreply@tu-dominio.gob.ec>
SUPERVISOR_EMAILS=supervisor1@tu-dominio.gob.ec,supervisor2@tu-dominio.gob.ec

# SMTP (solo si NOTIFICATIONS_ENABLED=true)
SMTP_HOST=smtp.tu-dominio.gob.ec
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=usuario_smtp
SMTP_PASS=CAMBIAR_PASSWORD_SMTP
