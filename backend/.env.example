# Puerto del servidor
PORT=3000

# Configuración MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=poa_pac

# Seguridad / autenticación
JWT_SECRET=cambia-este-valor-en-produccion
DEFAULT_ADMIN_USER=admin
DEFAULT_ADMIN_PASSWORD=12345

# Configuración SMTP para envío de correos
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu-email@gmail.com
SMTP_PASS=tu-password-de-aplicacion

# Email del remitente
EMAIL_FROM=Sistema Seguimiento <sistema@quitoturismo.gob.ec>

# Emails de supervisores (separados por coma)
SUPERVISOR_EMAILS=supervisor1@quitoturismo.gob.ec,supervisor2@quitoturismo.gob.ec

# Días de anticipación para alertas de vencimiento
ALERT_DAYS_BEFORE=3

# Activar notificaciones (true/false)
NOTIFICATIONS_ENABLED=true
